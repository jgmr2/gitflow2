PORT=5100

# MongoDB
# Local (docker-compose): usa el hostname del servicio "mongo".
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_this_password
MONGO_INITDB_DATABASE=auditoria_db
MONGO_URI=mongodb://admin:change_this_password@mongo:27017/auditoria_db?authSource=admin
# Render (sin docker-compose, no hay contenedor "mongo"): usa un clúster
# externo, ej. MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/auditoria_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=1h
